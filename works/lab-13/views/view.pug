doctype html
html
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title View Tests
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css")

  body
    section.section
      .container
        h1.title View tests

        each test in tests
          .card
            header.card-header
              p.card-header-title Test with #{test.diskNumber}

            .card-content
              .content
                p
                  | The total moves were 
                  strong #{test.totalMoves}
                  | . The first five were:

                ul
                  each val in test.firstFive
                    li= val

              .buttons
                form(action=`/test/view/${test.diskNumber}`, method="GET")
                  button.button.is-link(type="submit") View full
